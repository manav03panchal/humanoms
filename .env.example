# HumanOMS Configuration
HUMANOMS_PORT=3747
HUMANOMS_HOST=localhost
HUMANOMS_DB_PATH=./data/humanoms.db
# Required: passphrase for encrypting secrets
HUMANOMS_MASTER_KEY=
HUMANOMS_LOG_LEVEL=info

# Chat Provider: "claude-code", "anthropic", or "openai"
# claude-code uses `claude login` OAuth (no API key needed — ideal for Claude Max)
CHAT_PROVIDER=claude-code
# API key (not needed for claude-code)
CHAT_API_KEY=
# Optional: override model (default: claude-sonnet-4-6 / gpt-4o)
CHAT_MODEL=
# Optional: custom endpoint (e.g. https://api.moonshot.cn/v1)
CHAT_BASE_URL=
# Optional: max response tokens (default: 8192)
CHAT_MAX_TOKENS=

# Examples:
# Claude Max: CHAT_PROVIDER=claude-code  (no API key needed)
# Anthropic:  CHAT_PROVIDER=anthropic  CHAT_API_KEY=sk-ant-...
# OpenAI:     CHAT_PROVIDER=openai     CHAT_API_KEY=sk-...
# Kimi:       CHAT_PROVIDER=openai     CHAT_API_KEY=sk-...  CHAT_BASE_URL=https://api.moonshot.cn/v1  CHAT_MODEL=moonshot-v1-8k
# DeepSeek:   CHAT_PROVIDER=openai     CHAT_API_KEY=sk-...  CHAT_BASE_URL=https://api.deepseek.com/v1  CHAT_MODEL=deepseek-chat
# Groq:       CHAT_PROVIDER=openai     CHAT_API_KEY=gsk_... CHAT_BASE_URL=https://api.groq.com/openai/v1  CHAT_MODEL=llama-3.3-70b-versatile
# Ollama:     CHAT_PROVIDER=openai     CHAT_API_KEY=ollama  CHAT_BASE_URL=http://localhost:11434/v1  CHAT_MODEL=llama3.2

# External Services (stored encrypted in DB via scripts/add-secret.ts)
# discord_bot_token
# discord_channel_id
# api_key_hash
